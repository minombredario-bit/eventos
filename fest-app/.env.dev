# .env.dev  –  variables Docker Compose para entorno de desarrollo
# Uso: docker compose --env-file .env.dev -f docker-compose.dev.yml up -d
# NUNCA subas credenciales reales al repositorio

APP_VERSION=dev

# ── Superadmin bootstrap ────────────────────────────────────────────────────
# Crea el superadmin la primera vez que arranca el contenedor PHP
SUPERADMIN_EMAIL=superadmin@festapp.local
SUPERADMIN_PASSWORD=superadmin1234

# ── Ofelia SMTP → en dev todo va a Mailpit ──────────────────────────────────
OFELIA_SMTP_HOST=mailpit
OFELIA_SMTP_PORT=1025
OFELIA_SMTP_USER=
OFELIA_SMTP_PASSWORD=
OFELIA_MAIL_FROM=ofelia@festapp.local
