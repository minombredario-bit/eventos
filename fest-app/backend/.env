# .env  –  desarrollo local (Docker Compose)
# Las claves sensibles reales van en .env.local (nunca versionar)

APP_ENV=dev
APP_SECRET=dev_secret_change_me
APP_DEBUG=1

DB_NAME=festapp_db_dev
DB_USER=festapp_user
DB_PASSWORD=festapp_pass
DB_HOST=db
DB_PORT=3306
DB_SERVER_VERSION=8.0

DATABASE_URL="mysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?serverVersion=${DB_SERVER_VERSION}&charset=utf8mb4"

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=dev_jwt_passphrase

#DEFAULT_URI=http://localhost:8080
DEFAULT_URI=http://localhost:4250
# ── Mailer ──────────────────────────────────────────────────────────────────
# En dev todo va a Mailpit (UI → http://localhost:8025)
MAILER_DSN=smtp://mailpit:1025
MAILER_FROM=festapp@festapp.local

# ── Superadmin bootstrap ────────────────────────────────────────────────────
# Crea el superadmin la primera vez que arranca el contenedor PHP
SUPERADMIN_EMAIL=superadmin@festapp.local
SUPERADMIN_PASSWORD=superadmin1234

# ── Ofelia – alertas de error de jobs ───────────────────────────────────────
# En dev usamos el mismo Mailpit para capturar las alertas
OFELIA_SMTP_HOST=mailpit
OFELIA_SMTP_PORT=1025
OFELIA_SMTP_USER=
OFELIA_SMTP_PASSWORD=
OFELIA_MAIL_FROM=ofelia@festapp.local

# ── FTP (referencia para cliente FTP local) ──────────────────────────────────
FTP_HOST=localhost
FTP_PORT=21
FTP_USER=ftpuser
FTP_PASS=ftppass_dev

# ── Push (Notificaciones) ────────────────────────────────────────────────────
WEB_PUSH_PUBLIC_KEY=BADEOP1I8g6KRIElz3tUxCcLgno3pnGgv4FDO_3nXtB00L0RIsrvUy7JDFb0kyny3eTv6IGXBnd9hUnCdm4T5bI
WEB_PUSH_PRIVATE_KEY=oLiODD2bAql1yah8X03OH7GXlwy-gbbrljkmPnsYBAM
WEB_PUSH_SUBJECT=mailto:tu@email.com


