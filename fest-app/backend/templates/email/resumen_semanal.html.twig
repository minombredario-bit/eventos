{% extends 'email/base.html.twig' %}

{% block email_title %}Resumen semanal{% endblock %}
{% block email_preheader %}Resumen automático del proceso de envíos de la semana{% endblock %}
{% block email_heading %}Resumen semanal{% endblock %}

{% block content %}
    <p style="margin:0 0 18px;">Hola, se ha generado un resumen semanal para <strong>{{ destino }}</strong>.</p>

    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 24px; border-collapse:separate; border-spacing:0; background:#f8fafc; border:1px solid #e5e7eb; border-radius:18px; overflow:hidden;">
        <tr>
            <td style="padding:18px 20px; font-size:14px; line-height:1.75; color:#334155;">
                <div><strong>Intento:</strong> {{ intento }}</div>
            </td>
        </tr>
    </table>

    <p style="margin:0;">Si este correo se generó por error, revisa el proceso de envío programado antes de volver a lanzarlo.</p>
{% endblock %}
