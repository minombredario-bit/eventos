{% extends 'email/base.html.twig' %}

{% block email_title %}Acceso creado{% endblock %}
{% block email_preheader %}Tu cuenta ya está lista para empezar a usar Festapp{% endblock %}
{% block email_heading %}Bienvenido/a, {{ nombre }}{% endblock %}

{% block content %}
    <p style="margin:0 0 18px;">Tu usuario ha sido creado en la aplicación de la entidad y ya puedes iniciar sesión con las credenciales temporales.</p>

    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 24px; border-collapse:separate; border-spacing:0; background:#f8fafc; border:1px solid #e5e7eb; border-radius:18px; overflow:hidden;">
        <tr>
            <td style="padding:18px 20px; font-size:14px; line-height:1.7; color:#334155;">
                <div style="margin-bottom:8px;"><strong>Usuario:</strong> {{ email }}</div>
                <div style="margin-bottom:8px;"><strong>Contraseña temporal:</strong> {{ password }}</div>
                {% if appUri %}
                    <div><strong>Acceso:</strong> <a href="{{ appUri }}" style="color:#4f46e5; text-decoration:none; font-weight:700;">{{ appUri }}</a></div>
                {% endif %}
            </td>
        </tr>
    </table>

    <p style="margin:0 0 24px;">Por seguridad, cambia la contraseña en tu primer inicio de sesión y guarda la nueva en un lugar seguro.</p>

    {% if appUri %}
        <table role="presentation" cellspacing="0" cellpadding="0" border="0">
            <tr>
                <td style="border-radius:14px; background:#4f46e5;">
                    <a href="{{ appUri }}" style="display:inline-block; padding:14px 22px; color:#ffffff; text-decoration:none; font-weight:700;">Entrar en la aplicación</a>
                </td>
            </tr>
        </table>
    {% endif %}
{% endblock %}

